{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning", "System": "Warning" }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/duneflame-.txt", "rollingInterval": "Day", "retainedFileCountLimit": 7 } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_KEY_MUST_BE_VERY_LONG_AND_SECURE_123456!",
    "Issuer": "DuneFlameAPI",
    "Audience": "DuneFlameClient",
    "AccessTokenExpirationInMinutes": 15,
    "RefreshTokenExpirationInDays": 30
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "info@duneflame.com",
    "Password": "",
    "FromEmail": "info@duneflame.com",
    "FromName": "Dune & Flame Support"
  },
  "GoogleSettings": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "StripeSettings": {
    "SecretKey": "YOUR_STRIPE_SECRET_KEY",
    "PublishableKey": "YOUR_STRIPE_PUBLISHABLE_KEY",
    "WebhookSecret": "",
    "Products": {
      "BLRB": "price_1SxsAb2zD7Va1EOdAAtFSYfd",
